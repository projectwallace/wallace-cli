		"oxfmt": "^0.43.0",
		"oxlint": "^1.51.0",
		"publint": "^0.3.18",
		"tsdown": "^0.21.4",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	},
	"engines": {
		"node": ">=20.12.0"
	}
